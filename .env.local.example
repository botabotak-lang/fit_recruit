# お問い合わせフォーム メール送信設定（nodemailer）
# このファイルをコピーして .env.local を作成し、実際の値を設定してください。
# Vercel にデプロイする場合は、Vercel ダッシュボードの Environment Variables に同じキーで設定します。

# SMTP サーバーのホスト名
# Xserver: サーバーパネル「サーバー情報」の sv***.xserver.jp、または fit-ec.jp
# 例: sv12345.xserver.jp
SMTP_HOST=svXXXXX.xserver.jp

# SMTP ポート番号
# 587 = TLS（推奨）、465 = SSL、25 = 非暗号化
SMTP_PORT=587

# SMTP 認証ユーザー名（通常はメールアドレス）
SMTP_USER=toyo@fit-ec.com

# SMTP 認証パスワード
# Gmail の場合はアプリパスワードを使用してください（通常パスワードは不可）
SMTP_PASS=your-smtp-password
